{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Antigravity Tools Dev",
  "version": "3.3.15",
  "identifier": "dev.stranmor.antigravity-tools-dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Antigravity Tools Dev",
        "width": 1024,
        "height": 700,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {}
      }
    }
  },
  "mainBinaryName": "antigravity_tools_dev"
}